---
const mockups = [
  { id: '01', name: 'Stellar', file: 'mockup-01-stellar.html', accent: '#4F8EF7', desc: 'Star field · Electric blue' },
  { id: '02', name: 'Nebula', file: 'mockup-02-nebula.html', accent: '#A855F7', desc: 'Aurora gradient · Purple/cyan' },
  { id: '03', name: 'Terminal', file: 'mockup-03-terminal.html', accent: '#00FF41', desc: 'Monospace · Green on black' },
  { id: '04', name: 'Event Horizon', file: 'mockup-04-event-horizon.html', accent: '#F59E0B', desc: 'Pure black · Gold · Maximum minimal' },
  { id: '05', name: 'Linear Dark', file: 'mockup-05-linear-dark.html', accent: '#3B82F6', desc: 'Dot grid · Theo Brown energy' },
  { id: '06', name: 'Bento', file: 'mockup-06-bento.html', accent: '#6366F1', desc: 'Bento grid · Indigo' },
  { id: '07', name: 'Editorial', file: 'mockup-07-editorial.html', accent: '#D97706', desc: 'Playfair · Magazine · Gold' },
  { id: '08', name: 'Minimal Light', file: 'mockup-08-minimal-light.html', accent: '#1E3A5F', desc: 'Light · Navy · Timeline' },
  { id: '09', name: 'Void', file: 'mockup-09-void.html', accent: '#F5F0E8', desc: 'Pure black · Cream · Zero chrome' },
  { id: '10', name: 'Signal', file: 'mockup-10-signal.html', accent: '#10B981', desc: 'OpenHome inspired · Animated glow' },
]
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mockups — Review</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --bg: #0a0a0a; --surface: #111; --border: rgba(255,255,255,0.08); --text: #f0f0f0; --muted: #666; }
    html, body { height: 100%; overflow: hidden; font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif; background: var(--bg); color: var(--text); }

    .layout { display: flex; height: 100vh; }

    /* Sidebar */
    .sidebar {
      width: 220px;
      flex-shrink: 0;
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      overflow-y: auto;
    }
    .sidebar-header {
      padding: 16px;
      border-bottom: 1px solid var(--border);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .mockup-btn {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 12px 16px;
      border: none;
      background: transparent;
      cursor: pointer;
      text-align: left;
      border-bottom: 1px solid var(--border);
      transition: background .15s;
      width: 100%;
    }
    .mockup-btn:hover { background: rgba(255,255,255,0.04); }
    .mockup-btn.active { background: rgba(255,255,255,0.07); }
    .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
      margin-top: 4px;
    }
    .btn-info { flex: 1; min-width: 0; }
    .btn-name { font-size: 13px; font-weight: 500; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .btn-num { font-size: 10px; color: var(--muted); }
    .btn-desc { font-size: 10px; color: var(--muted); margin-top: 2px; line-height: 1.3; }

    /* Preview */
    .preview { flex: 1; position: relative; overflow: hidden; }
    .preview iframe {
      width: 100%;
      height: 100%;
      border: none;
      display: block;
    }

    /* Top bar */
    .topbar {
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 36px;
      background: rgba(10,10,10,0.85);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 16px;
      z-index: 10;
    }
    .topbar-name { font-size: 12px; font-weight: 500; color: var(--text); }
    .topbar-open {
      font-size: 11px;
      color: var(--muted);
      text-decoration: none;
      padding: 3px 8px;
      border: 1px solid var(--border);
      border-radius: 4px;
      transition: color .15s, border-color .15s;
    }
    .topbar-open:hover { color: var(--text); border-color: rgba(255,255,255,0.2); }
    .preview-inner {
      position: absolute;
      inset: 36px 0 0 0;
    }
    .preview-inner iframe { width: 100%; height: 100%; border: none; }
  </style>
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <div class="sidebar-header">10 mockups</div>
      {mockups.map((m, i) => (
        <button
          class={`mockup-btn${i === 0 ? ' active' : ''}`}
          data-file={`/mockups/${m.file}`}
          data-name={`${m.id} · ${m.name}`}
        >
          <span class="dot" style={`background: ${m.accent}`}></span>
          <span class="btn-info">
            <span class="btn-name">{m.name}</span>
            <span class="btn-desc">{m.desc}</span>
          </span>
          <span class="btn-num">{m.id}</span>
        </button>
      ))}
    </aside>

    <div class="preview">
      <div class="topbar">
        <span class="topbar-name" id="current-name">01 · Stellar</span>
        <a id="open-link" href="/mockups/mockup-01-stellar.html" target="_blank" class="topbar-open">Ouvrir ↗</a>
      </div>
      <div class="preview-inner">
        <iframe id="frame" src="/mockups/mockup-01-stellar.html" title="Mockup preview"></iframe>
      </div>
    </div>
  </div>

  <script>
    document.querySelectorAll('.mockup-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.mockup-btn').forEach(b => b.classList.remove('active'))
        btn.classList.add('active')
        document.getElementById('frame').src = btn.dataset.file
        document.getElementById('current-name').textContent = btn.dataset.name
        document.getElementById('open-link').href = btn.dataset.file
      })
    })
  </script>
</body>
</html>
