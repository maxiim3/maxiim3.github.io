---
/**
 * Header Component - Story 1.5
 * Site header with language switch navigation
 */
interface Props {
  currentLocale: string; // 'fr' or 'en' from Astro.currentLocale
}

const { currentLocale } = Astro.props;

// Determine alternate locale
const alternateLocale = currentLocale === 'fr' ? 'en' : 'fr';

// Determine alternate URL
const alternateUrl = currentLocale === 'fr' ? '/en/' : '/';

// Determine language switch label
const languageLabel = currentLocale === 'fr' ? 'EN' : 'FR';

// Bilingual subtitle
const subtitle = currentLocale === 'fr'
  ? 'Développeur Front-End Vue/Nuxt'
  : 'Front-End Developer Vue/Nuxt';

// Current language display
const currentLanguageDisplay = currentLocale === 'fr' ? 'Français' : 'English';
---

<header>
  <h1>Maxime Tamburrini</h1>
  <p>{subtitle}</p>

  <!-- Language switch navigation -->
  <nav aria-label="Language">
    <span class="current-language" aria-label="Current language">{currentLanguageDisplay}</span>
    <span aria-hidden="true"> | </span>
    <a href={alternateUrl} lang={alternateLocale} class="language-switch">
      {languageLabel}
    </a>
  </nav>
</header>
